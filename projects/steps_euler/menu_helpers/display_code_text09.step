step: display_code_text09
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console

        display("note: =========================================")
        display("note: CODE FOR PROBLEM_09")
        display("note: =========================================")
        display("step: problem_09")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("      ")
        display("    declare:")
        display("        sum_target as number")
        display("        results as list")
        display("        triplet as list")
        display("        a as number")
        display("        b as number")
        display("        c as number")
        display("        product as number")
        display("        ")
        display("    do:")
        display("        call time storing result in start")
        display("        set sum_target to 1000.0")
        display("        ")
        display("        note: Delegating the mathematical search to the helpers floor")
        display("        call find_triplets_by_sum with sum_target storing result in results")
        display("        ")
        display("        note: Project Euler #9 specifies exactly one triplet exists")
        display("        set triplet to results[0]")
        display("        ")
        display("        set a to triplet[0]")
        display("        set b to triplet[1]")
        display("        set c to triplet[2]")
        display("        set product to (a * b * c)")
        display("")
        display("        display(\"###################################\")")
        display("        display(\"PROJECT EULER PROBLEM  9\")")
        display("        display(\"###################################\") ")
        display("        display(\"\") ")
        display("        display(\"There exists exactly one Pythagorean\") ")
        display("        display(\"triplet for which a + b + c = 1000.\") ")
        display("        display(\"Find the product abc.\")")
        display("        display(\"\") ")
        display("        display(\"The product is\" added to product) ")
        display("        display(\"###################################\") ")
        display(" ")
        display("        call time storing result in finish")
        display("        set elapsed to (finish - start)")
        display("        display(\"Prosessing time: \" added to elapsed as text added to \" seconds.\")")
        display("")
        display("")
        display("note: =========================================")
        display("note: HELPER CODE - FIND_TRIPLETS_BY_SUM")
        display("note: =========================================")
        display("step: find_triplets_by_sum")
        display("    ")
        display("    belongs to: solution_helpers")
        display("    expects: sum")
        display("    returns: triplets")
        display("    ")
        display("    declare:")
        display("        max as number")
        display("        a as number")
        display("        num as number")
        display("        den as number")
        display("        b as number")
        display("        b_int as number")
        display("        c as number")
        display("        triplet as list")
        display("        ")
        display("           ")
        display("    do:             ")
        display("        note: S/3 is the mathematical limit for 'a' because a < b < c")
        display("        note: We use a simple loop. Each 'a' is a float (e.g., 1.0, 2.0...)")
        display("        set max to sum / 3 ")
        display("        set a to 1.0")
        display("        set triplets to []")
        display("        ")
        display("        repeat while a is less than max")
        display("            display(\"note: b = (S^2 - 2Sa) / (2S - 2a)\") ")
        display("            set num to (sum * sum) - (2.0 * sum * a)")
        display("            set den to (2.0 * sum) - (2.0 * a)")
        display("            ")
        display("            set b to num / den")
        display("            call round with (num / den) storing result in b_int")
        display("        ")
        display("            note: Check if b is an \"integer\" in Steps")
        display("            note: We do this by comparing b to its rounded-down version")
        display("            if b equals b_int ")
        display("                set c to sum - a - b")
        display("                set triplet to [a, b, c]")
        display("                add triplet to triplets ")
        display("        ")
        display("            set a to a + 1.0")
        display("            ")
        display("        return triplets")
