        display("step: fib_even_sum")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: max")
        display("    returns: even_total")
        display("")
        display("    declare:")
        display("        fsum as number")
        display("        first as number")
        display("        second as number")
        display("        even_total as number ")
        display("    ")
        display("    do: ")
        display("        set fsum to 0")
        display("        set first to 1")
        display("        set second to 2")
        display("        set even_total to 2")
        display("        ")
        display("        repeat while fsum is less than max")
        display("            set fsum to first + second")
        display("            if fsum % 2 equals 0")
        display("                set even_total to even_total + fsum")
        display("            set first to second")
        display("            set second to fsum")
        display("                        ")
        display("        return even_total")