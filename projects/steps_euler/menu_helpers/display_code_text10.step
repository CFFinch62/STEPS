step: display_code_text10
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console
        
        display("note: =========================================")
        display("note: CODE FOR PROBLEM_10")
        display("note: =========================================")
        display("step: problem_10")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("")
        display("    note: PROJECT EULER - PROBLEM 10")
        display("    note: Find the sum of all the primes below two million.")
        display("    note: Expected answer: 142,913,828,922")
        display("    note:")
        display("    note: ALGORITHM: Sieve of Eratosthenes")
        display("    note:   1. create_list(n+1, true)  -- native builtin, allocates at C speed")
        display("    note:   2. Mark 0 and 1 as not prime")
        display("    note:   3. For each i from 2 to sqrt(n): mark all multiples of i as false")
        display("    note:   4. Collect surviving indices into a primes list")
        display("    note:   5. Sum the primes list")
        display("    note:")
        display("    note: WHY THIS IS FASTER THAN THE ORIGINAL TRIAL DIVISION:")
        display("    note:   Trial division tested every odd candidate up to 2,000,000 with an")
        display("    note:   inner loop running up to sqrt(candidate) for each one -- roughly")
        display("    note:   94 million inner iterations through the interpreter.")
        display("    note:   The sieve outer marking loop only runs to sqrt(2,000,000) = ~1,414")
        display("    note:   with total marking work of ~3-4 million iterations (O(n log log n)).")
        display("    note:   That is roughly a 25x reduction in interpreted loop iterations.")
        display("    note:")
        display("    note: LANGUAGE LIMITATION NOTE FOR STUDENTS:")
        display("    note:   Even with the most efficient algorithm, the final collection and")
        display("    note:   summation loops must visit all 2,000,000 sieve entries through the")
        display("    note:   Steps interpreter. Every index access involves scope lookup, type")
        display("    note:   dispatch, and object allocation inside Python. Python itself solves")
        display("    note:   this entire problem in milliseconds using native C data structures.")
        display("    note:   This illustrates a real ceiling of tree-walking interpreted languages:")
        display("    note:   for problems requiring millions of simple operations, a compiled or")
        display("    note:   natively-optimised language will always win by orders of magnitude.")
        display("    note:   Steps is excellent for learning logic and problem-solving; for raw")
        display("    note:   numeric throughput at this scale, reach for Python, Go, or Rust.")
        display("")
        display("    declare:")
        display("        max as number")
        display("        primes as list")
        display("        total as number")
        display("        i as number")
        display("        start as number")
        display("        finish as number")
        display("        elapsed as number")
        display("")
        display("    do:")
        display("        call time storing result in start")
        display("")
        display("        set max to 2000000")
        display("")
        display("        display \"Calculation in progress - building sieve to \" added to max as text added to \"...\"")
        display("        call gen_primes_to_n with max storing result in primes")
        display("")
        display("        display \"Sieve complete. Summing primes...\"")
        display("        set total to 0")
        display("        set i to 0")
        display("        repeat while i is less than (length of primes)")
        display("            set total to total + primes[i]")
        display("            set i to i + 1")
        display("")
        display("        call time storing result in finish")
        display("        set elapsed to finish - start")
        display("")
        display("        display \"###################################\"")
        display("        display \"PROJECT EULER PROBLEM 10\"")
        display("        display \"###################################\"")
        display("        display \"\"")
        display("        display \"Find the sum of all the primes below\"")
        display("        display \"two million.\"")
        display("        display \"\"")
        display("        display \"The sum is: \" added to total as text")
        display("        display \"\"")
        display("        display \"Processing time: \" added to elapsed as text added to \" seconds.\"")
        display("        display \"###################################\"")   
        display("")
        display("")
        display("note: =========================================")
        display("note: HELPER CODE - GEN_PRIMES_TO_N")
        display("note: =========================================")
        display("step: gen_primes_to_n")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: n as number")
        display("    returns: primes as list")
        display("")
        display("    riser: build_sieve")
        display("        expects: size as number")
        display("        returns: primes_sieve as list")
        display("")
        display("        declare:")
        display("            primes_sieve as list")
        display("")
        display("        do:")
        display("            note: create_list is a native builtin - allocates at C speed,")
        display("            note: replacing a 2,000,000-iteration interpreted loop with one call.")
        display("            call create_list with size + 1, true storing result in primes_sieve")
        display("            return primes_sieve")
        display("")
        display("    declare:")
        display("        sieve as list")
        display("        primes as list")
        display("        i as number")
        display("        multiple as number")
        display("        root as number")
        display("        whole as number")
        display("")
        display("    do:")
        display("        call build_sieve with n storing result in sieve")
        display("        set sieve[0] to false")
        display("        set sieve[1] to false")
        display("")
        display("        call sqrt with n storing result in root")
        display("        call round with root storing result in whole")
        display("")
        display("        set i to 2")
        display("        repeat while i is less than or equal to whole")
        display("            if sieve[i] equals true")
        display("                set multiple to i * i")
        display("                repeat while multiple is less than or equal to n")
        display("                    set sieve[multiple] to false")
        display("                    set multiple to multiple + i")
        display("            set i to i + 1")
        display("")
        display("        set primes to []")
        display("        set i to 0")
        display("        repeat while i is less than or equal to n")
        display("            if sieve[i] equals true")
        display("                add i to primes")
        display("            set i to i + 1")
        display("")
        display("        return primes")    
