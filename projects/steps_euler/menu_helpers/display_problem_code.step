step: display_problem_code
    
    belongs to: menu_helpers
    expects: problem
    returns: nothing  
            
    do:
        clear console
            
        if problem equals "1" 
            call display_code_text01 
        otherwise if problem equals "2" 
            call display_code_text02
        otherwise if problem equals "3" 
            call display_code_text03
        otherwise if problem equals "4"
            call display_code_text04
        otherwise if problem equals "5"
            call display_code_text05
        otherwise if problem equals "6" 
            call display_code_text06
        otherwise if problem equals "7" 
            call display_code_text07
        otherwise if problem equals "8" 
            call display_code_text08
        otherwise if problem equals "9"
            call display_code_text09
        otherwise if problem equals "10"
            call display_code_text10
        otherwise
            display "Invalid Selection!" 