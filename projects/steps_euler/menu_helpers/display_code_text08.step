step: display_code_text08
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console
        
        display("note: =========================================")
        display("note: CODE FOR PROBLEM_08")
        display("note: =========================================")
        display("step: problem_08")
        display("")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("      ")
        display("    declare:")
        display("        data as list")
        display("        size as number")
        display("        answer as number")
        display("        ")
        display("    do:")
        display("        set data to \"\"")
        display("        ")
        display("        set size to 13")
        display("        ")
        display("        call time storing result in start")
        display("        ")
        display("        call max_adjacent_product with data, size storing result in answer")
        display("")
        display("        display(\"###################################\")")
        display("        display(\"PROJECT EULER PROBLEM 8\")")
        display("        display(\"###################################\") ")
        display("        display(\"Find the product of thirteen adjacent\")")
        display("        display(\"digits in the 1000 digit number that\")")
        display("        display(\"have the greatest product.\")")
        display("        display(\"\")  ")
        display("        display(\"The product is: \" added to answer)")
        display("        display(\"###################################\")")
        display(" ")
        display("        call time storing result in finish")
        display("        set elapsed to (finish - start)")
        display("        display(\"Prosessing time: \" added to elapsed as text added to \" seconds.\")")      
        display("")
        display("")
        display("note: =========================================")
        display("note: HELPER CODE - MAX_ADJACENT_PRODUCT")
        display("note: =========================================")
        display("step: max_adjacent_product")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: digit_string as text, window_size as number")
        display("    returns: best as number")
        display("    ")
        display("    declare:")
        display("        cnt as number")
        display("        max as number")
        display("        best as number")
        display("        tmp as number")
        display("        window as text")
        display("        zero_pos as number")
        display("        digit_list as list")
        display("        i as number")
        display("        searching as boolean")
        display("    ")
        display("    do:")
        display("        set best to 0")
        display("        set cnt to 0")
        display("        set max to (length of digit_string - window_size)")
        display("        set searching to true")
        display("    ")
        display("        repeat while searching")
        display("            call slice with digit_string, cnt, cnt + window_size storing result in window")
        display("            call index_of with window, \"0\" storing result in zero_pos")
        display("    ")
        display("            if zero_pos is equal to -1")
        display("                set tmp to 1")
        display("                set i to 0")
        display("                call characters with window storing result in digit_list")
        display("                repeat while i is less than window_size")
        display("                    set tmp to tmp * digit_list[i] as number")
        display("                    set i to i + 1")
        display("                if tmp is greater than best")
        display("                    set best to tmp")
        display("                set cnt to cnt + 1")
        display("            otherwise")
        display("                set cnt to cnt + zero_pos + 1")
        display("    ")
        display("            if cnt is greater than max")
        display("                set searching to false")
        display("    ")
        display("        return best")
