        display("note: HELPER CODE - LCM (Least Common Multiple)")
        display("note: =========================================")
        display("step: lcm ")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: n1, n2")
        display("    returns: least_cm")
        display("    ")
        display("    declare:")
        display("        num1 as number")
        display("        num2 as number")
        display("        tmp as number")
        display("        least as number")
        display("")
        display("    do:    ")
        display("        set num1 to n1")
        display("        set num2 to n2")
        display("        set tmp to 0")
        display("        ")
        display("        call gcd with num1, num2 storing result in tmp")
        display("        ")
        display("        set least to (num1 * num2) / tmp ")
        display("         ")
        display("        return least")
        display("")
        display("")        
        display("note: =========================================")
        display("note: HELPER CODE - GCD (Greatest Common Divisor)")
        display("note: =========================================")
        display("step: gcd")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: n1, n2")
        display("    returns: num1")
        display("    ")
        display("    declare:")
        display("        tmp as number")
        display("        num1 as number")
        display("        num2 as number")
        display("        ")
        display("    do:    ")
        display("        set tmp to 0")
        display("        set num1 to n1")
        display("        set num2 to n2   ")
        display("")
        display("        repeat while num2 is greater than 0")
        display("            set tmp to num1 % num2")
        display("            set num1 to num2")
        display("            set num2 to tmp")
        display("")
        display("        return num1")