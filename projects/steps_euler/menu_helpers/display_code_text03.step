step: display_code_text03
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console
        
        display("note: =========================================")
        display("note: CODE FOR PROBLEM_03")
        display("note: =========================================")
        display("step: problem_03")
        display("")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("      ")
        display("    declare:")
        display("        max as number")
        display("        answer as number")
        display("        start as number")
        display("        finish as number")
        display("        elapsed as number")
        display("        ")
        display("    do:")
        display("        set max to 600851475143")
        display("        ")
        display("        call time storing result in start")
        display("        ")
        display("        call gpf with max storing result in answer")
        display("")
        display("        display(\"###################################\")")
        display("        display(\"PROJECT EULER PROBLEM 3\")")
        display("        display(\"###################################\") ")
        display("        display(\"\")")
        display("        display(\"What is the largest prime factor of \")")
        display("        display(\"the number 600851475143?\")")
        display("        display(\"\")  ")
        display("        display(\"The GPF is: \" added to answer)")
        display("        display(\"###################################\")")
        display(" ")
        display("        call time storing result in finish")
        display("        set elapsed to (finish - start)")
        display("        display(\"Prosessing time: \" added to elapsed as text added to \" seconds.\")")
        display("")
        display("")
        display("note: =========================================")
        display("note: CODE FOR GPF")
        display("note: =========================================")
        display("step: gpf")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: max")
        display("    returns: largest")
        display("")
        display("    declare:")
        display("        n as number")
        display("        factor as number")
        display("")
        display("    do:")
        display("        note: Trial division - divide n down as factors are found.")
        display("        note: Any factor found this way must be prime since all smaller")
        display("        note: factors have already been divided out. No is_prime needed.")
        display("        note: Runs in ~sqrt(n) iterations vs ~n*sqrt(n) for the naive approach.")
        display("")
        display("        set largest to 1")
        display("        set n to max")
        display("        set factor to 2")
        display("")
        display("        repeat while (factor * factor) is less than or equal to n")
        display("            repeat while (n % factor) equals 0")
        display("                set largest to factor")
        display("                set n to n / factor")
        display("            set factor to factor + 1")
        display("")
        display("        if n is greater than 1")
        display("            set largest to n")
        display("")
        display("        return largest")
