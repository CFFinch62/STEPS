step: display_code_text04
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console
        
        display("note: =========================================")
        display("note: CODE FOR PROBLEM_04")
        display("note: =========================================")
        display("step: problem_04")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("      ")
        display("    declare:")
        display("        answer as number")
        display("        start as number")
        display("        finished as number")
        display("        elapsed as number")
        display("        ")
        display("    riser: max_pal")
        display("        expects: nothing")
        display("        returns: pal")
        display("")
        display("        declare:")
        display("            i as number")
        display("            j as number")
        display("            num as number")
        display("            tmp as text")
        display("            rev as text")
        display("            outer_done as boolean")
        display("            inner_done as boolean")
        display("")
        display("        do:")
        display("            set pal to 0")
        display("            set i to 999")
        display("            set outer_done to false")
        display("")
        display("            repeat while i is greater than 99 and not outer_done")
        display("                note: if best possible product for this i can't beat pal, we're done")
        display("                if i * 999 is less than or equal to pal")
        display("                    set outer_done to true")
        display("                if not outer_done")
        display("                    set j to 999")
        display("                    set inner_done to false")
        display("                    repeat while j is greater than or equal to i and not inner_done")
        display("                        set num to i * j")
        display("                        note: products only decrease from here, skip the rest")
        display("                        if num is less than or equal to pal")
        display("                            set inner_done to true")
        display("                        if not inner_done")
        display("                            set tmp to num as text")
        display("                            call reverse with tmp storing result in rev")
        display("                            if tmp equals rev")
        display("                                if num is greater than pal")
        display("                                    set pal to num")
        display("                        set j to j - 1")
        display("                    set i to i - 1")
        display("                otherwise")
        display("                    set i to 0")
        display("")
        display("            return pal")
        display("    ")
        display("    note: main procedure")
        display("    do:")
        display("        set answer to 0")
        display("")
        display("        call time storing result in start")
        display("    ")
        display("        call max_pal storing result in answer ")
        display("")
        display("        display(\"###################################\")")
        display("        display(\"PROJECT EULER PROBLEM 4\")")
        display("        display(\"###################################\") ")
        display("        display(\"\")")
        display("        display(\"Find the largest palindrome made from \")")
        display("        display(\"the product of two 3-digit numbers.\")")
        display("        display(\"\")  ")
        display("        display(\"Largest Palindrome is: \" added to answer)")
        display("        display(\"###################################\")")
        display(" ")
        display("        call time storing result in finish")
        display("        set elapsed to (finish - start)")
        display("        display(\"Prosessing time: \" added to elapsed as text added to \" seconds.\")")