step: display_code_text01
    
    belongs to: menu_helpers
    expects: nothing
    returns: nothing  
            
    do:
        clear console
        
        display("note: =========================================")
        display("note: MAIN SOLUTION CODE FOR PROBLEM_01")
        display("note: =========================================")
        display("step: problem_01")
        display("    belongs to: solutions")
        display("    expects: nothing")
        display("    returns: nothing")
        display("      ")
        display("    note: SET VARIBLES")
        display("    declare:")
        display("        M1 as number")
        display("        M2 as number")
        display("        LIMIT as number")
        display("        answer as number")
        display("        ")
        display("    note: MAIN PROGRAM")
        display("    do:")
        display("        set M1 to 3")
        display("        set M2 to 5")
        display("        set LIMIT to 999")
        display("        set answer to 0")
        display("        ")
        display("        call time storing result in start")
        display("        ")
        display("        display(\"calling sum_of_two_multiples...\")")
        display("        call sum_of_two_multiples with M1, M2, LIMIT storing result in answer")
        display("")
        display("        display(\"#################################\")")
        display("        display(\"PROJECT EULER PROBLEM 1\")")
        display("        display(\"#################################\")")
        display("        display(\"Find the sum of all the multiples\")")
        display("        display(\"of 3 or 5 below 1000.\")")
        display("        display(\"\")     ")
        display("        display(\"Sum is: \" added to answer)")
        display("        display(\"#################################\")")
        display("        ")
        display("        call time storing result in finish")
        display("        set elapsed to (finish - start)")
        display("        display(\"Prosessing time: \" added to elapsed as text added to \" seconds.\")")
        display("")
        display("")
        display("note: =========================================")
        display("note: HELPER CODE - SUM_OF_TWO_MULTIPLES")
        display("note: =========================================")
        display("step: sum_of_two_multiples")
        display("")
        display("    belongs to: solution_helpers")
        display("    expects: number1, number2, max")
        display("    returns: total")
        display("    ")
        display("    declare:")
        display("        sum as number")
        display("        count as number")
        display("")
        display("    do:")
        display("        set sum to 0")
        display("        set count to 0")
        display("        ")
        display("        repeat while count is less than or equal to max - 1")
        display("            set count to count + 1")
        display("            if (count % number1 equals 0) or (count % number2 equals 0) ")
        display("                set sum to sum + count          ")
        display("                ")
        display("        return sum")   