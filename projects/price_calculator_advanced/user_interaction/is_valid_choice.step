step: is_valid_choice
    belongs to: user_interaction
    expects: choice as number
    returns: valid as text

    declare:
        valid as text

    do:
        if choice is greater than or equal to 1
            if choice is less than or equal to 5
                set valid to "yes"
            otherwise
                set valid to "no"
        otherwise
            set valid to "no"

        return valid
