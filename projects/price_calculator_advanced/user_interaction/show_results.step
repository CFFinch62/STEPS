step: show_results
    belongs to: user_interaction
    expects: results as table
    returns: nothing

    declare:
        price_text as text
        margin_text as text
        profit_text as text
        markup_text as text
        cost_text as text

    do:
        set price_text to (results["price"] as decimal(2)) as text
        set margin_text to (results["margin"] as decimal(2)) as text
        set profit_text to (results["profit"] as decimal(2)) as text
        set markup_text to (results["markup"] as decimal(2)) as text
        set cost_text to (results["cost"] as decimal(2)) as text
        
        clear console

        display ""
        call banner with "CALCULATED RESULTS", 45 storing result in b
        display b
        display ""
        display "              Price: $" added to price_text
        display "             Margin:  " added to margin_text added to "%"
        display "             Profit: $" added to profit_text
        display "             Markup:  " added to markup_text added to "%"
        display "               Cost: $" added to cost_text
        display ""
