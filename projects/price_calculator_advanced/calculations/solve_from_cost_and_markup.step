step: solve_from_cost_and_markup
    belongs to: calculations
    expects: cost as number, markup as number
    returns: results as table

    declare:
        price as number
        profit as number
        margin as number
        results as table

    do:
        set price to cost * (1 + (markup / 100))
        set profit to price - cost
        set margin to (profit / price) * 100

        set results to ["price": price, "margin": margin, "profit": profit, "markup": markup, "cost": cost]
        return results
