step: solve_from_cost_and_profit
    belongs to: calculations
    expects: cost as number, profit as number
    returns: results as table

    declare:
        price as number
        margin as number
        markup as number
        results as table

    do:
        set price to cost + profit
        set margin to (profit / price) * 100
        set markup to (profit / cost) * 100

        set results to ["price": price, "margin": margin, "profit": profit, "markup": markup, "cost": cost]
        return results
