step: solve_from_profit_and_markup
    belongs to: calculations
    expects: profit as number, markup as number
    returns: results as table

    declare:
        cost as number
        price as number
        margin as number
        results as table

    do:
        set cost to profit / (markup / 100)
        set price to cost + profit
        set margin to (profit / price) * 100

        set results to ["price": price, "margin": margin, "profit": profit, "markup": markup, "cost": cost]
        return results
