step: solve_from_profit_and_margin
    belongs to: calculations
    expects: profit as number, margin as number
    returns: results as table

    declare:
        price as number
        cost as number
        markup as number
        results as table

    do:
        set price to profit / (margin / 100)
        set cost to price - profit
        set markup to (profit / cost) * 100

        set results to ["price": price, "margin": margin, "profit": profit, "markup": markup, "cost": cost]
        return results
