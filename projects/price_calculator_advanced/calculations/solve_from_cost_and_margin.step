step: solve_from_cost_and_margin
    belongs to: calculations
    expects: cost as number, margin as number
    returns: results as table

    declare:
        price as number
        profit as number
        markup as number
        results as table

    do:
        set price to cost / (1 - (margin / 100))
        set profit to price - cost
        set markup to (profit / cost) * 100

        set results to ["price": price, "margin": margin, "profit": profit, "markup": markup, "cost": cost]
        return results
